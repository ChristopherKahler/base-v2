## BASE v2 — ops: Ontology
## Proactive context-injection engine vocabulary.
##
## Namespace: http://ops-sys.local/ontology#
##
## IRI scheme (path/slug-based, stable identity):
##   Projects:   ops:project/{slug}         e.g. ops:project/casegate-v2
##   Tasks:      ops:task/{project}/{slug}   e.g. ops:task/casegate-v2/fix-auth
##   Decisions:  ops:decision/{domain}/{slug}
##   Entities:   ops:entity/{slug}           e.g. ops:entity/chris-kahler
##   Workspaces: ops:workspace/{slug}        e.g. ops:workspace/chris-ai-systems
##   Domains:    ops:domain/{slug}            e.g. ops:domain/casegate
##   Rules:      ops:rule/{domain}/{n}        e.g. ops:rule/casegate/0
##   Goals:      ops:goal/{slug}
##   Reminders:  ops:reminder/{slug}
##   Documents:  ops:document/{path-hash}
##   PaulProjects: ops:paul/{slug}
##
## Named graphs:
##   ops:graph/global            → .base-gbl/graph.trig
##   ops:graph/ws/{slug}         → {workspace}/.base/graph.trig

@prefix ops:  <http://ops-sys.local/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .

# ─── Classes ──────────────────────────────────────────────

ops:Project       rdf:type rdfs:Class ;
                  rdfs:label "Project" ;
                  rdfs:comment "A tracked project (app, framework, tracking)" .

ops:App           rdf:type rdfs:Class ;
                  rdfs:subClassOf ops:Project ;
                  rdfs:label "App" .

ops:Framework     rdf:type rdfs:Class ;
                  rdfs:subClassOf ops:Project ;
                  rdfs:label "Framework" .

ops:TrackingProject rdf:type rdfs:Class ;
                    rdfs:subClassOf ops:Project ;
                    rdfs:label "TrackingProject" .

ops:Task          rdf:type rdfs:Class ;
                  rdfs:label "Task" .

ops:Decision      rdf:type rdfs:Class ;
                  rdfs:label "Decision" ;
                  rdfs:comment "A recorded decision with rationale and recall context" .

ops:Entity        rdf:type rdfs:Class ;
                  rdfs:label "Entity" ;
                  rdfs:comment "A person, organization, or named thing" .

ops:Person        rdf:type rdfs:Class ;
                  rdfs:subClassOf ops:Entity ;
                  rdfs:label "Person" .

ops:Organization  rdf:type rdfs:Class ;
                  rdfs:subClassOf ops:Entity ;
                  rdfs:label "Organization" .

ops:Goal          rdf:type rdfs:Class ;
                  rdfs:label "Goal" ;
                  rdfs:comment "A measurable objective with target and current values" .

ops:Reminder      rdf:type rdfs:Class ;
                  rdfs:label "Reminder" .

ops:Workspace     rdf:type rdfs:Class ;
                  rdfs:label "Workspace" ;
                  rdfs:comment "A workspace directory registered in the global tier" .

ops:Domain        rdf:type rdfs:Class ;
                  rdfs:label "Domain" ;
                  rdfs:comment "A domain-matching rule group from domains.toml" .

ops:Rule          rdf:type rdfs:Class ;
                  rdfs:label "Rule" ;
                  rdfs:comment "A single rule within a domain" .

ops:Document      rdf:type rdfs:Class ;
                  rdfs:label "Document" ;
                  rdfs:comment "A knowledge document extracted via MOP (frontmatter)" .

ops:PaulProject   rdf:type rdfs:Class ;
                  rdfs:label "PaulProject" ;
                  rdfs:comment "A PAUL-managed project indexed read-only from paul.json" .

ops:Note          rdf:type rdfs:Class ;
                  rdfs:label "Note" ;
                  rdfs:comment "A structured memory entry with relational edges (base learn)" .

# ─── Core predicates ──────────────────────────────────────

ops:name          rdf:type rdf:Property ;
                  rdfs:domain rdfs:Resource ;
                  rdfs:range xsd:string ;
                  rdfs:label "name" .

ops:description   rdf:type rdf:Property ;
                  rdfs:domain rdfs:Resource ;
                  rdfs:range xsd:string ;
                  rdfs:label "description" .

ops:status        rdf:type rdf:Property ;
                  rdfs:domain rdfs:Resource ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Values: active, completed, blocked, deferred, superseded, archived" .

ops:priority      rdf:type rdf:Property ;
                  rdfs:domain rdfs:Resource ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Values: urgent, high, medium, low" .

ops:lastActive    rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Timestamp of last activity on this entity" .

ops:createdAt     rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime .

ops:updatedAt     rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime .

# ─── Relationship predicates ──────────────────────────────

ops:supersedes    rdf:type rdf:Property ;
                  rdfs:comment "Points to the prior version this entity replaced" .

ops:supersededBy  rdf:type rdf:Property ;
                  rdfs:comment "Inverse of supersedes" .

ops:belongsTo     rdf:type rdf:Property ;
                  rdfs:range ops:Workspace ;
                  rdfs:comment "Entity → workspace membership" .

ops:hasDomain     rdf:type rdf:Property ;
                  rdfs:range ops:Domain ;
                  rdfs:comment "Project/workspace → domain association" .

ops:hasRule       rdf:type rdf:Property ;
                  rdfs:domain ops:Domain ;
                  rdfs:range ops:Rule ;
                  rdfs:comment "Domain → rule containment" .

ops:hasGoal       rdf:type rdf:Property ;
                  rdfs:range ops:Goal ;
                  rdfs:comment "Entity → goal linkage (cross-tier)" .

ops:hasTask       rdf:type rdf:Property ;
                  rdfs:domain ops:Project ;
                  rdfs:range ops:Task ;
                  rdfs:comment "Project → task containment" .

ops:hasProject    rdf:type rdf:Property ;
                  rdfs:domain ops:Workspace ;
                  rdfs:range ops:Project ;
                  rdfs:comment "Workspace → project containment" .

# ─── Scalar predicates ────────────────────────────────────

ops:blockedBy     rdf:type rdf:Property ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Free-text blocker description" .

ops:nextAction    rdf:type rdf:Property ;
                  rdfs:range xsd:string .

ops:revenue       rdf:type rdf:Property ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Revenue description (e.g. '$33/mo recurring')" .

ops:dueDate       rdf:type rdf:Property ;
                  rdfs:range xsd:date .

ops:staleThreshold rdf:type rdf:Property ;
                   rdfs:range xsd:integer ;
                   rdfs:comment "Days before entity is considered stale" .

ops:rationale     rdf:type rdf:Property ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Rationale for a decision" .

ops:recall        rdf:type rdf:Property ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Recall/trigger context for a decision" .

ops:ruleText      rdf:type rdf:Property ;
                  rdfs:domain ops:Rule ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The rule content text" .

ops:triggerKeyword rdf:type rdf:Property ;
                   rdfs:domain ops:Domain ;
                   rdfs:range xsd:string ;
                   rdfs:comment "A keyword that activates this domain (legacy, prefer promptKeyword/fileKeyword)" .

ops:promptKeyword rdf:type rdf:Property ;
                  rdfs:domain ops:Domain ;
                  rdfs:range xsd:string ;
                  rdfs:comment "A user-configured keyword matched against prompt text" .

ops:fileKeyword   rdf:type rdf:Property ;
                  rdfs:domain ops:Domain ;
                  rdfs:range xsd:string ;
                  rdfs:comment "A code-oriented keyword matched against file content on tool-use" .

ops:triggerPath   rdf:type rdf:Property ;
                  rdfs:domain ops:Domain ;
                  rdfs:range xsd:string ;
                  rdfs:comment "A path glob that activates this domain" .

ops:hasDecision   rdf:type rdf:Property ;
                  rdfs:domain ops:Domain ;
                  rdfs:range ops:Decision ;
                  rdfs:comment "Domain → decision linkage" .

ops:path          rdf:type rdf:Property ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Filesystem path associated with this entity" .

# ─── Note predicates ─────────────────────────────────────

ops:noteText      rdf:type rdf:Property ;
                  rdfs:domain ops:Note ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The memory content text" .

ops:noteType      rdf:type rdf:Property ;
                  rdfs:domain ops:Note ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Type: insight, correction, decision, commitment, shift" .

ops:relatedTo     rdf:type rdf:Property ;
                  rdfs:domain ops:Note ;
                  rdfs:comment "Edge from Note to any entity (domain, project, person)" .

# ─── PAUL extraction classes (synced 2026-06-10, AUDIT I8) ──

ops:Milestone     rdf:type rdfs:Class ;
                  rdfs:label "Milestone" ;
                  rdfs:comment "A milestone (epic) within a project" .

ops:FileChange    rdf:type rdfs:Class ;
                  rdfs:label "FileChange" ;
                  rdfs:comment "A file created/modified by a PAUL plan" .

ops:AcceptanceCriteria rdf:type rdfs:Class ;
                  rdfs:label "AcceptanceCriteria" ;
                  rdfs:comment "An acceptance criterion defined in a PAUL plan" .

ops:AcceptanceCriteriaResult rdf:type rdfs:Class ;
                  rdfs:label "AcceptanceCriteriaResult" ;
                  rdfs:comment "Pass/fail result for an acceptance criterion" .

ops:LedgerEntry   rdf:type rdfs:Class ;
                  rdfs:label "LedgerEntry" ;
                  rdfs:comment "A PAUL session ledger entry (plan/apply/unify action)" .

ops:OperatorNote  rdf:type rdfs:Class ;
                  rdfs:label "OperatorNote" ;
                  rdfs:comment "A note authored by the operator in document frontmatter" .

# ─── Predicates synced from code usage (2026-06-10, AUDIT I8) ──

ops:hasMilestone  rdf:type rdf:Property ;
                  rdfs:comment "Project → Milestone edge" .

ops:hasTag        rdf:type rdf:Property ;
                  rdfs:comment "Entity → tag string" .

ops:hasSection    rdf:type rdf:Property ;
                  rdfs:comment "Document → section heading" .

ops:hasAC         rdf:type rdf:Property ;
                  rdfs:comment "Plan → AcceptanceCriteria edge" .

ops:hasACResult   rdf:type rdf:Property ;
                  rdfs:comment "Summary → AcceptanceCriteriaResult edge" .

ops:hasFileChange rdf:type rdf:Property ;
                  rdfs:comment "Plan/Summary → FileChange edge" .

ops:operatorNote  rdf:type rdf:Property ;
                  rdfs:comment "Entity → operator-authored note text" .

ops:due           rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Reminder due timestamp" .

ops:text          rdf:type rdf:Property ;
                  rdfs:comment "Generic text content" .

ops:index         rdf:type rdf:Property ;
                  rdfs:comment "Stable numeric index (CLI-added rules)" .

ops:source        rdf:type rdf:Property ;
                  rdfs:comment "Provenance marker (e.g. \"domains.toml\" on synced rules)" .

ops:sourceFile    rdf:type rdf:Property ;
                  rdfs:comment "Source file path for code/document entities" .

ops:targetFile    rdf:type rdf:Property ;
                  rdfs:comment "File path a FileChange applies to" .

ops:filePath      rdf:type rdf:Property ;
                  rdfs:comment "File path attribute" .

ops:documentType  rdf:type rdf:Property ;
                  rdfs:comment "Document classification (plan, summary, context, ...)" .

ops:lastExtracted rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "When extraction last touched this entity" .

ops:lastMentioned rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Flow mention tracking: last mention timestamp" .

ops:mentionCount  rdf:type rdf:Property ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Flow mention tracking: occurrence count" .

ops:resurfaceAt   rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Flow: when to resurface this item" .

ops:action        rdf:type rdf:Property ;
                  rdfs:comment "LedgerEntry action (plan, apply, unify)" .

ops:phase         rdf:type rdf:Property ;
                  rdfs:comment "PAUL phase number/name" .

ops:plan          rdf:type rdf:Property ;
                  rdfs:comment "PAUL plan identifier" .

ops:planType      rdf:type rdf:Property ;
                  rdfs:comment "PAUL plan type (execute, tdd, research)" .

ops:wave          rdf:type rdf:Property ;
                  rdfs:comment "PAUL execution wave number" .

ops:autonomous    rdf:type rdf:Property ;
                  rdfs:range xsd:boolean ;
                  rdfs:comment "PAUL plan has no checkpoints" .

ops:dependsOn     rdf:type rdf:Property ;
                  rdfs:comment "Plan → prior plan dependency" .

ops:affects       rdf:type rdf:Property ;
                  rdfs:comment "Summary → future phases needing this context" .

ops:subsystem     rdf:type rdf:Property ;
                  rdfs:comment "Primary subsystem categorization" .

ops:duration      rdf:type rdf:Property ;
                  rdfs:comment "Recorded duration" .

ops:actualDuration rdf:type rdf:Property ;
                  rdfs:comment "Measured duration after completion" .

ops:started       rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Start timestamp" .

ops:completed     rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Completion timestamp" .

ops:timestamp     rdf:type rdf:Property ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Generic event timestamp" .

ops:criterion     rdf:type rdf:Property ;
                  rdfs:comment "AcceptanceCriteria text" .

ops:changeType    rdf:type rdf:Property ;
                  rdfs:comment "FileChange kind (created, modified, deleted)" .

ops:fromPlan      rdf:type rdf:Property ;
                  rdfs:comment "Entity → originating PAUL plan" .

ops:gitRange      rdf:type rdf:Property ;
                  rdfs:comment "Commit range associated with a plan" .

ops:goal          rdf:type rdf:Property ;
                  rdfs:comment "Stated goal text" .

ops:purpose       rdf:type rdf:Property ;
                  rdfs:comment "Stated purpose text" .

ops:note          rdf:type rdf:Property ;
                  rdfs:comment "Attached note text" .

ops:notes         rdf:type rdf:Property ;
                  rdfs:comment "Attached notes text (plural form used by extractors)" .

ops:accomplishments rdf:type rdf:Property ;
                  rdfs:comment "Summary accomplishments text" .

ops:deviation     rdf:type rdf:Property ;
                  rdfs:comment "Summary deviation entry" .

ops:impact        rdf:type rdf:Property ;
                  rdfs:comment "Recorded impact statement" .

ops:nextPhaseReadiness rdf:type rdf:Property ;
                  rdfs:comment "Summary next-phase readiness text" .

ops:references    rdf:type rdf:Property ;
                  rdfs:comment "Entity → referenced resource" .

ops:scopeLimit    rdf:type rdf:Property ;
                  rdfs:comment "Plan scope limit entry" .

ops:tasksCompleted rdf:type rdf:Property ;
                  rdfs:range xsd:integer ;
                  rdfs:comment "Count of tasks completed in a plan" .

ops:filesModified rdf:type rdf:Property ;
                  rdfs:comment "Files a PAUL plan modifies" .
